# Application
APP_NAME=Customer Support Resolution Agent
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/support_agent.db

# OpenAI (required for RAG + Agent)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=support_knowledge

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# LLM
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Security
RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
SECRET_KEY=change-this-to-a-random-secret-key

# Goodwill Credit
MAX_GOODWILL_CREDIT=10.00

# Refund
REFUND_WINDOW_DAYS=30
